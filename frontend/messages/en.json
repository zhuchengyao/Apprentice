    "features": {
      "upload_title": "Upload any book",
      "upload_body": "PDF, EPUB, plain text. Paste a link, drop a file — we handle the rest.",
      "extract_title": "Intelligent extraction",
      "extract_body": "Claude reads every chapter, surfaces each concept, builds a knowledge graph.",
      "teach_title": "Active teaching",
      "teach_body": "Your tutor explains, quizzes, and adapts — one concept at a time.",
      "remember_title": "Remember forever",
      "remember_body": "Spaced repetition schedules the perfect moment to review and retain."
    },
    "philosophy": {
      "eyebrow": "Philosophy",
      "heading_line1": "Built for the way",
      "heading_line2": "humans actually learn.",
      "one_title": "Learning is a conversation",
      "one_body": "Lectures fade. Dialogue sticks. Apprentice turns every book into a patient tutor who asks the right question at the right time.",
      "two_title": "Depth over speed",
      "two_body": "Don't race through chapters. Master a concept, then move. The tutor waits until you're ready — then gently pushes forward.",
      "three_title": "Your curriculum, your pace",
      "three_body": "From Feynman to a physics textbook to your grandmother's cookbook. Any source. Any depth. Any language."
    },
    "quote": {
      "body": "\u201CIf you can\u2019t explain it to a six-year-old, you don\u2019t understand it yourself.\u201D",
      "attr": "— Attributed to Richard Feynman"
    },
    "testimonials": {
      "eyebrow": "From the shelves",
      "heading_line1": "What readers are",
      "heading_line2": "actually saying.",
      "featured_quote": "\u201CI\u2019ve tried a few AI learning tools before, but this one actually helps me finish books instead of just skimming. The structured breakdown into concepts makes a big difference, especially for technical material.\u201D",
      "featured_name": "AlexChen92",
      "featured_role": "March 2026",
      "items": {
        "mika": {
          "quote": "The \u2018continue reading\u2019 flow is surprisingly effective. It removes the friction of deciding what to do next. I usually just open the app and pick up where I left off without thinking too much.",
          "name": "mika_reading",
          "role": "March 2026"
        },
        "dev": {
          "quote": "As someone working in engineering, I like that the explanations don\u2019t oversimplify. The AI tutor can go into enough depth while still being interactive. It feels closer to a real study session.",
          "name": "dev_goto",
          "role": "March 2026"
        },
        "sophia": {
          "quote": "I mainly use it for non-fiction. The way it extracts key points and reorganizes them makes dense content much more manageable. It\u2019s not perfect, but it saves me a lot of time.",
          "name": "sophia_lin",
          "role": "April 2026"
        },
        "takashi": {
          "quote": "The interface is clean, and it doesn\u2019t try to overwhelm you with features. The focus on learning one concept at a time works well for me.",
          "name": "takashi_k",
          "role": "April 2026"
        },
        "data": {
          "quote": "I was skeptical about AI explanations, but the quality is fairly consistent. Occasionally I double-check things, but overall it\u2019s reliable enough for daily study.",
          "name": "data_aria",
          "role": "April 2026"
        },
        "leonard": {
          "quote": "What stands out is the continuity. It remembers what I\u2019ve been working on and keeps the learning flow going. Most reading apps don\u2019t get that right.",
          "name": "leonard_w",
          "role": "April 2026"
        }
      }
    },
