# Database
DATABASE_URL=postgresql+asyncpg://apprentice:apprentice@localhost:5432/apprentice
POSTGRES_USER=apprentice
POSTGRES_PASSWORD=apprentice
POSTGRES_DB=apprentice

# Redis
REDIS_URL=redis://localhost:6379

# AI Provider: "anthropic" or "openai"
AI_PROVIDER=anthropic
AI_MODEL=              # leave empty for provider default (claude-sonnet-4-20250514 / gpt-4o)

# API Keys (only the one matching AI_PROVIDER is required)
ANTHROPIC_API_KEY=your-api-key-here
OPENAI_API_KEY=your-api-key-here

# Backend
BACKEND_URL=http://localhost:8000
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3000/api
